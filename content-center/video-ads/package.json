{
  "name": "anansi-atlas-video-ads",
  "version": "1.0.0",
  "description": "Remotion compositions for Anansi Atlas LinkedIn ad commercials (add-on, not app code).",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "vo": "node scripts/generate-vo.mjs",
    "build": "node scripts/build.mjs",
    "build:scheduled": "node scripts/build-scheduled.mjs",
    "render:showcase": "remotion render PlatformShowcase out/platform-showcase.mp4",
    "render:pilot": "remotion render PilotSignup out/pilot-signup.mp4",
    "render:all": "npm run render:showcase && npm run render:pilot",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "typescript": "^5.4.0"
  }
}
